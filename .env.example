# ============================================================
# APEX IA — Variables de Entorno
# Copiá este archivo como .env y completá los valores.
# NUNCA commiteés el archivo .env al repositorio.
# ============================================================

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...
DATABASE_URL=postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# ---- Redis (Upstash) ----
REDIS_URL=rediss://default:...@...upstash.io:6380
REDIS_TOKEN=...

# ---- Auth ----
JWT_SECRET=change-me-32-chars-minimum-secret

# ---- WhatsApp Oficial (Meta Cloud API) ----
WHATSAPP_CLOUD_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
META_APP_SECRET=

# ---- Facebook Messenger ----
FACEBOOK_VERIFY_TOKEN=

# ---- Telegram ----
TELEGRAM_BOT_TOKEN=

# ---- TikTok ----
TIKTOK_APP_ID=
TIKTOK_APP_SECRET=

# ---- AI Providers ----
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GOOGLE_GEMINI_API_KEY=AIza...
OPENROUTER_API_KEY=sk-or-...

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ---- Mercado Pago ----
MP_ACCESS_TOKEN=APP_USR-...
MP_WEBHOOK_SECRET=

# ---- Email ----
RESEND_API_KEY=re_...
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# ---- App URLs ----
NEXT_PUBLIC_APP_URL=http://localhost:3000
API_URL=http://localhost:3001
NODE_ENV=development

# ---- Encriptación de credenciales de canales ----
# Generar con: openssl rand -hex 32
ENCRYPTION_KEY=

# ---- Monitoring ----
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# ---- Tests ----
TEST_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
